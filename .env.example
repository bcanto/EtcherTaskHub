# ══════════════════════════════════════════════════════════════════════════════
# Etcher Task Hub — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.
# .env is already in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# The service role key has FULL database access and bypasses RLS.
# NEVER expose this to the browser or commit it anywhere.
# Only use server-side (Edge Functions, backend jobs).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Bucket name for task file attachments (create in Supabase Dashboard → Storage)
SUPABASE_STORAGE_BUCKET=task-attachments

# ── Application ───────────────────────────────────────────────────────────────
# Set to 'production' in prod, 'development' locally
APP_ENV=development

# Public URL of this app (used for redirect URLs in auth emails)
APP_URL=http://localhost:3001

# ── Email (Optional — Supabase handles auth emails by default) ────────────────
# Only needed if you're using a custom SMTP relay
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@etchersolutions.com
