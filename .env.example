# ══════════════════════════════════════════════════════════════════════════════
# Etcher Task Hub — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.
# .env is already in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# The service role key has FULL database access and bypasses RLS.
# NEVER expose this to the browser or commit it anywhere.
# Only use server-side (Edge Functions, backend jobs).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Bucket name for task file attachments (create in Supabase Dashboard → Storage)
SUPABASE_STORAGE_BUCKET=task-attachments

# ── Application ───────────────────────────────────────────────────────────────
# Set to 'production' in prod, 'development' locally
APP_ENV=development

# Public URL of this app (used for redirect URLs in auth emails)
APP_URL=http://localhost:3001

# ── Email Intake — Microsoft Graph API ───────────────────────────────────────
# Required to activate the Email Triage Zone (see SETUP.md for full instructions)
# Leave blank to keep the UI active but inactive (test with "+ Test email" button)
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_SECRET=your-azure-ad-client-secret
MAILBOX_UPN=taskhub@etchersolutions.com
# Public HTTPS URL for Graph webhook delivery (use ngrok in dev)
WEBHOOK_URL=https://xxxx.ngrok.io
# URL where serve.mjs is running (email-intake.mjs posts parsed emails here)
TASKHUB_API=http://localhost:3001

# ── Email (Optional — Supabase handles auth emails by default) ────────────────
# Only needed if you're using a custom SMTP relay
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@etchersolutions.com
